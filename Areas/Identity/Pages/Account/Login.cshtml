@page
@model LoginModel

@{
    ViewData["Title"] = "Вход";
}

<h1 class="mb-4">@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-4">
        <section class="card shadow-sm border-0 p-4">
            <form id="account" method="post">
                <h4 class="mb-3">Вход с локален акаунт</h4>
                <hr />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.EmailOrNickname" class="form-control" autocomplete="username" aria-required="true" placeholder="Имейл или Псевдоним" />
                    <label asp-for="Input.EmailOrNickname" class="form-label">Имейл или Псевдоним</label>
                    <span asp-validation-for="Input.EmailOrNickname" class="text-danger"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Парола" />
                    <label asp-for="Input.Password" class="form-label">Парола</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label class="form-check-label" asp-for="Input.RememberMe">Запомни ме</label>
                </div>

                <div class="d-grid mb-3">
                    <button id="login-submit" type="submit" class="btn btn-lg btn-primary w-100">
                        Вход
                    </button>
                </div>

                <div class="mb-3">
                    <p><a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Регистрация на нов акаунт</a></p>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    h1, h4 {
        color: #007bff;
    }

    .card {
        border-radius: 15px;
        background: linear-gradient(135deg, #fefefe, #f0f0f0);
    }

    .btn-primary, .btn-outline-primary {
        border-radius: 8px;
        font-size: 0.95rem;
        transition: transform 0.2s;
    }

        .btn-primary:hover, .btn-outline-primary:hover {
            transform: translateY(-2px);
        }

    .form-floating input.form-control {
        height: 3rem;
    }
</style>
