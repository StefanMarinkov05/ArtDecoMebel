@model ArtDecoMebel.Models.Furniture

@{
    ViewData["Title"] = "Изтриване на мебел";
    var imgPng = Url.Content($"~/Mebeli/furniture{Model.Id}.png");
    var imgJpg = Url.Content($"~/Mebeli/furniture{Model.Id}.jpg");
    var defaultImg = Url.Content("~/Mebeli/default.png");
}

<h1 class="mb-4">Изтриване на:@Model.FType?.Name @Model.Name</h1>

<div class="row g-4">
    <div class="col-md-4 text-center">
        <img src="@imgPng" alt="@Model.Name" class="img-fluid rounded shadow mb-3"
             onerror="this.onerror=null;this.src='@imgJpg'; this.onerror=function(){this.src='@defaultImg';}" />
    </div>
    <div class="col-md-8">
        <dl class="row">
            <dt class="col-sm-4">Марка</dt>
            <dd class="col-sm-8">@Model.Brand?.Name</dd>

            <dt class="col-sm-4">Помещение</dt>
            <dd class="col-sm-8">@Model.Room?.Name</dd>

            <dt class="col-sm-4">Размери (см)</dt>
            <dd class="col-sm-8">@Model.Length.ToString("0.##") × @Model.Width.ToString("0.##") × @Model.Height.ToString("0.##")</dd>

            <dt class="col-sm-4">Производство</dt>
            <dd class="col-sm-8">@Model.ProductionYear</dd>

            <dt class="col-sm-4">Цветове</dt>
            <dd class="col-sm-8">
                @(Model.Colors?.Any() == true ? string.Join(", ", Model.Colors.Select(c => c.Name)) : "Няма")
            </dd>

            <dt class="col-sm-4">Материали</dt>
            <dd class="col-sm-8">
                @(Model.Materials?.Any() == true ? string.Join(", ", Model.Materials.Select(m => m.Name)) : "Няма")
            </dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger me-2">
                <i class="bi bi-trash-fill"></i> Потвърди изтриване
            </button>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left-circle"></i> Отказ и обратно към списъка
            </a>
        </form>
    </div>
</div>

<style>
    .img-fluid {
        max-height: 400px;
        object-fit: cover;
    }

    dt {
        font-weight: 600;
        font-size: 1rem;
    }

    dd {
        font-size: 0.95rem;
    }

    .btn i {
        margin-right: 0.3rem;
    }
</style>
