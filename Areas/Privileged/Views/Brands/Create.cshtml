@model ArtDecoMebel.Models.Brand

@{
    ViewData["Title"] = "Създаване на марка";
}

<h1 class="mb-4">Създаване на нова марка</h1>

<div class="card shadow-sm p-4 mb-4">
    <h4 class="mb-3">Попълнете информацията за марката</h4>

    <form asp-action="Create" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

        <div class="col-md-6">
            <label asp-for="Name" class="form-label fw-bold"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="col-12 mt-3">
            <button type="submit" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Създай
            </button>
            <a class="btn btn-secondary" asp-action="Index">
                <i class="bi bi-arrow-left"></i> Назад към списъка
            </a>
        </div>
    </form>
</div>

<style>
    .form-label {
        font-size: 1rem;
    }

    .btn {
        font-size: 0.95rem;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
