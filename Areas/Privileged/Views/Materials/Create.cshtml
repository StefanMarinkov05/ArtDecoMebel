@model ArtDecoMebel.Models.Material

@{
    ViewData["Title"] = "Създаване";
}

<h1 class="mb-4">Добавяне на нов материал</h1>

<div class="card p-4 shadow-sm border-0" style="max-width: 500px;">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label">Име на материала</label>
            <input asp-for="Name" class="form-control" placeholder="Въведете име" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <input type="submit" value="Създай" class="btn btn-primary" />
            <a asp-action="Index" class="btn btn-secondary">Откажи</a>
        </div>
    </form>
</div>
