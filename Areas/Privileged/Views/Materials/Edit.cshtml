@model ArtDecoMebel.Models.Material

@{
    ViewData["Title"] = "Редакция";
}

<h1 class="mb-4">Редакция на материал</h1>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" class="card p-3 shadow-sm border-0">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Име</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between">
                <input type="submit" value="Запази" class="btn btn-success" />
                <a asp-action="Index" class="btn btn-secondary">Откажи</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
