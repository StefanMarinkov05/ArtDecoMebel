@model ArtDecoMebel.Models.ApplicationUser

@{
    ViewData["Title"] = "Редактиране на потребител";
}

<div class="container mt-5">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-primary text-white rounded-top-3">
            <h3 class="mb-0">
                <i class="bi bi-person-circle"></i> @ViewData["Title"]
            </h3>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Nickname" class="form-label fw-bold">Псевдоним</label>
                    <input asp-for="Nickname" class="form-control form-control-lg" required />
                    <span asp-validation-for="Nickname" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-bold">Имейл</label>
                    <input asp-for="Email" class="form-control form-control-lg" required />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label fw-bold">Телефон</label>
                    <input asp-for="PhoneNumber" class="form-control form-control-lg" required />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-secondary btn-lg shadow-sm">
                        <i class="bi bi-arrow-left"></i> Отказ
                    </a>
                    <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                        <i class="bi bi-save"></i> Запази
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
