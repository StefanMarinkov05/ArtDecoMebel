@model ApplicationUser

@{
    ViewData["Title"] = "Добавяне на потребител";
}

<div class="container mt-5">
    <h2 class="text-center text-primary mb-4"><i class="bi bi-person-plus"></i> Добавяне на потребител</h2>

    <div class="row justify-content-center">
        <div class="col-md-6">
            <form asp-action="Create" method="post" class="p-4 shadow-lg rounded-4 bg-light">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-3">
                    <label asp-for="Nickname" class="form-label fw-bold">Псевдоним</label>
                    <input asp-for="Nickname" class="form-control shadow-sm" required placeholder="Въведете псевдоним..." />
                    <span asp-validation-for="Nickname" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-bold">Имейл</label>
                    <input asp-for="Email" type="email" class="form-control shadow-sm" required placeholder="example@mail.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label fw-bold">Телефон</label>
                    <input asp-for="PhoneNumber" class="form-control shadow-sm" required placeholder="+359..." />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Парола</label>
                    <input type="password" name="password" class="form-control shadow-sm" required placeholder="********" />
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary btn-lg shadow-sm">
                        <i class="bi bi-arrow-left"></i> Отказ
                    </a>
                    <button type="submit" class="btn btn-success btn-lg shadow-sm">
                        <i class="bi bi-check-circle"></i> Създай
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
