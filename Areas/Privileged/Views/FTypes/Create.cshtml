@model ArtDecoMebel.Models.FType

@{
    ViewData["Title"] = "Създай категория";
}

<h1 class="mb-3 text-primary">Създай нова категория</h1>

<div class="card p-4 shadow-sm mb-3">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label fw-semibold">Име на категория</label>
            <input asp-for="Name" class="form-control" placeholder="Въведете име" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Създай
        </button>
        <a asp-action="Index" class="btn btn-secondary ms-2">
            <i class="bi bi-arrow-left"></i> Обратно към списъка
        </a>
    </form>
</div>
