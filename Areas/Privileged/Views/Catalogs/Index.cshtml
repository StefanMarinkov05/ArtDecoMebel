@model IEnumerable<ArtDecoMebel.Models.Catalog>

@{
    ViewData["Title"] = "Каталози";
}

<h1 class="mb-4">Каталози</h1>

<table class="table table-hover shadow-sm">
    <thead class="table-light">
        <tr>
            <th>Потребител</th>
            <th>Имейл</th>
            <th>Име на каталог</th>
            <th class="text-end">Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ApplicationUser.Id</td>
                <td>@item.ApplicationUser.Email</td>
                <td>@item.Name</td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info me-1" title="Преглед на каталог">
                        <i class="bi bi-eye"></i> Виж
                    </a>

                    <form asp-area="Privileged"
                          asp-controller="Catalogs"
                          asp-action="DeleteConfirmed"
                          method="post"
                          style="display: inline;"
                          onsubmit="return confirm('Сигурни ли сте, че искате да изтриете каталог \'@item.Name\'?');">

                        <input type="hidden" name="id" value="@item.Id" />

                        @Html.AntiForgeryToken()

                        <button type="submit" class="btn btn-danger btn-sm">
                            <i class="bi bi-trash"></i> Изтрий
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<style>
    h1 {
        color: #007bff;
    }

    .table {
        border-radius: 10px;
        overflow: hidden;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.1);
    }

    .btn {
        font-size: 0.85rem;
        border-radius: 8px;
    }

        .btn i {
            margin-right: 3px;
        }
</style>
