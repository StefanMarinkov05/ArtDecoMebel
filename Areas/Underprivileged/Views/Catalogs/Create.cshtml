@model ArtDecoMebel.Models.Catalog

@{
    ViewData["Title"] = "Създаване на каталог";
}

<h1 class="mb-4 text-gradient">Създаване на каталог</h1>

<div class="card shadow-lg p-4 mb-4 bg-gradient-card">
    <h4 class="mb-3 text-gradient-subtitle">Детайли за каталога</h4>
    <hr class="divider-gradient" />

    <div class="row">
        <div class="col-md-5">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group mb-3">
                    <label asp-for="Name" class="form-label fw-bold">Име</label>
                    <input asp-for="Name" class="form-control form-control-gradient" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-gradient-success px-4 shadow-sm">
                    Създай
                </button>
            </form>
        </div>
    </div>
</div>

<a asp-action="Index" class="btn btn-outline-gradient-secondary shadow-sm mb-4">Обратно към списъка</a>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    /* Page Title Gradient */
    .text-gradient {
        font-size: 2.5rem;
        font-weight: bold;
        background: linear-gradient(90deg, #ff7e5f, #feb47b, #86a8e7);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: fadeInUp 1s ease-out;
    }

    .text-gradient-subtitle {
        font-size: 1.3rem;
        background: linear-gradient(90deg, #f8ff00, #3ad59f);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* Card Gradient Background */
    .bg-gradient-card {
        background: linear-gradient(145deg, rgba(255,126,95,0.1), rgba(134,168,231,0.1));
        border-radius: 15px;
        transition: transform 0.3s, box-shadow 0.3s;
    }

        .bg-gradient-card:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 15px 25px rgba(0,0,0,0.2);
        }

    /* Divider Gradient */
    .divider-gradient {
        border-top: 2px solid;
        border-image: linear-gradient(to right, #ff7e5f, #feb47b, #86a8e7) 1;
    }

    /* Input Field Gradient */
    .form-control-gradient {
        border-radius: 10px;
        border: 1px solid #ccc;
        background: linear-gradient(145deg, rgba(255,255,255,0.1), rgba(0,0,0,0.05));
        transition: box-shadow 0.3s, transform 0.2s;
    }

        .form-control-gradient:focus {
            box-shadow: 0 0 8px rgba(134,168,231,0.5);
            transform: scale(1.02);
            border-color: #86a8e7;
        }

    /* Button Gradient Styles */
    .btn-gradient-success {
        background: linear-gradient(135deg, #28a745, #7ed957);
        color: white;
        border: none;
        border-radius: 50px;
        transition: transform 0.2s, box-shadow 0.3s;
    }

        .btn-gradient-success:hover {
            transform: translateY(-2px) scale(1.05);
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        }

    .btn-outline-gradient-secondary {
        border: 2px solid transparent;
        background: linear-gradient(white, white) padding-box, linear-gradient(90deg, #ff7e5f, #feb47b, #86a8e7) border-box;
        border-radius: 50px;
        color: #333;
        transition: transform 0.2s, box-shadow 0.3s;
    }

        .btn-outline-gradient-secondary:hover {
            transform: translateY(-2px) scale(1.03);
            box-shadow: 0 8px 16px rgba(0,0,0,0.2);
        }

    
</style>
