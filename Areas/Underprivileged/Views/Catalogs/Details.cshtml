@model ArtDecoMebel.Models.Catalog

@{
    ViewData["Title"] = "Детайли на каталог";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="text-primary mb-0">@Model.Name</h1>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Назад
        </a>
        <form asp-area="Underprivileged" asp-controller="Catalogs" asp-action="DeleteConfirmed"
              asp-route-id="@Model.Id" method="post"
              style="display: inline;"
              onsubmit="return confirm('Сигурни ли сте, че искате да изтриете каталог \'@Model.Name\'?');">

            <button type="submit" class="btn btn-danger btn-sm">
                <i class="bi bi-trash"></i> Изтрий
            </button>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0 p-3 mb-4">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken() <i class="bi bi-check-circle"></i>
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="UserId" />

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="input-group">
            <input asp-for="Name" class="form-control" placeholder="Име на каталога" />
            <button type="submit" class="btn btn-success">
                <i class="bi bi-check-circle"></i> Запази промяната
            </button>
        </div>
        <span asp-validation-for="Name" class="text-danger"></span>
    </form>
</div>

@if (Model.Furnitures != null && Model.Furnitures.Any())
{
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3">
        @foreach (var furn in Model.Furnitures)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 card-hover position-relative">

                    <form asp-area="Underprivileged" asp-controller="Catalogs" asp-action="RemoveFurniture" method="post"
                          class="position-absolute" style="top: 10px; right: 10px; z-index: 10;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="catalogId" value="@Model.Id" />
                        <input type="hidden" name="furnitureId" value="@furn.Id" />
                        <button type="submit" class="btn btn-light btn-sm rounded-circle shadow-sm border-0"
                                title="Премахни от каталога"
                                style="width: 32px; height: 32px; line-height: 1; padding: 0;"
                                onclick="return confirm('Премахване на @furn.Name?');">
                            ❌
                        </button>
                    </form>

                    @{
                        var imgPng = Url.Content($"~/Mebeli/furniture{furn.Id}.png");
                        var imgJpg = Url.Content($"~/Mebeli/furniture{furn.Id}.jpg");
                        var defaultImg = Url.Content("~/Mebeli/default.png");
                    }
                    <img src="@imgPng" class="card-img-top" alt="@furn.Name"
                         onerror="this.onerror=null;this.src='@imgJpg'; this.onerror=function(){this.src='@defaultImg';}" />

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold">@furn.Name</h5>
                        <p class="mb-1"><strong>Тип:</strong> @furn.FType?.Name</p>
                        <p class="mb-1"><strong>Произведен:</strong> @furn.ProductionYear г.</p>

                        <div class="mt-auto d-flex gap-2">
                            <a asp-area="Underprivileged" asp-controller="Furnitures" asp-action="Details" asp-route-id="@furn.Id"
                               class="btn btn-primary btn-sm flex-grow-1">
                                <i class="bi bi-eye"></i> Виж повече
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <p class="text-muted fst-italic">В този каталог няма добавени мебели.</p>
}

<style>
    .card-hover {
        border-radius: 15px;
        overflow: hidden;
        transition: transform 0.3s, box-shadow 0.3s;
        background: linear-gradient(135deg, #fefefe, #f0f0f0);
    }

        .card-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.25);
        }

    .card-img-top {
        height: 120px;
        object-fit: cover;
        border-bottom: 3px solid #007bff;
    }

    .card-title {
        font-size: 1rem;
        color: #007bff;
    }

    .card-body p {
        font-size: 0.8rem;
    }

    .card-footer .btn {
        font-size: 0.75rem;
        padding: 0.25rem 0.4rem;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
