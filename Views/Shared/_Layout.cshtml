<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - АртДекоМебел</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ArtDecoMebel.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container-fluid">

                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house-door"></i> АртДекоМебел
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-area="Underprivileged" asp-controller="Home" asp-action="Index">Начало</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-area="Underprivileged" asp-controller="Home" asp-action="Contacts">Контакти</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-area="Underprivileged" asp-controller="Furnitures" asp-action="Index">Мебели</a>
                        </li>
                         @if (User.Identity?.IsAuthenticated ?? false)
                         {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Underprivileged" asp-controller="Catalogs" asp-action="Index">Моите каталози</a>
                            </li>
                         }


                        @if (User.Identity.IsAuthenticated && User.IsInRole(ArtDecoMebel.Configuration.AppConfiguration.PrivilegedRoleString))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    Управление
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-area="Privileged" asp-controller="Users" asp-action="Index">Потребители</a></li>
                                    <li><a class="dropdown-item" asp-area="Privileged" asp-controller="Furnitures" asp-action="Index">Мебели</a></li>
                                    <li><a class="dropdown-item" asp-area="Privileged" asp-controller="Colors" asp-action="Index">Цветове</a></li>
                                    <li><a class="dropdown-item" asp-area="Privileged" asp-controller="Materials" asp-action="Index">Материали</a></li>
                                    <li><a class="dropdown-item" asp-area="Privileged" asp-controller="Rooms" asp-action="Index">Помещения</a></li>
                                    <li><a class="dropdown-item" asp-area="Privileged" asp-controller="Brands" asp-action="Index">Марки</a></li>
                                    <li><a class="dropdown-item" asp-area="Privileged" asp-controller="FTypes" asp-action="Index">Категории</a></li>
                                    <li><a class="dropdown-item" asp-area="Privileged" asp-controller="Catalogs" asp-action="Index">Каталози</a></li>
                                </ul>
                            </li>
                        }

                    </ul>

                    @using Microsoft.AspNetCore.Identity
                    @using ArtDecoMebel.Models
                    @inject UserManager<ApplicationUser> UserManager

                    <ul class="navbar-nav">
                        @if (User.Identity.IsAuthenticated)
                        {
                            var appUser = await UserManager.GetUserAsync(User); 
                            <li class="nav-item">
                                <span class="navbar-text me-2">
                                    <i class="bi bi-person-circle"></i> Здравей, @appUser.Nickname
                                </span>
                            </li>

                            <li class="nav-item">
                                <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
                                    <button class="btn btn-outline-light btn-sm">
                                        <i class="bi bi-box-arrow-right"></i> Изход
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">
                                    <i class="bi bi-box-arrow-in-right"></i> Вход
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">
                                    <i class="bi bi-person-plus"></i> Регистрация
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container my-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
